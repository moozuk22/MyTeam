generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Member {
  id          String                 @id @default(uuid())
  firstName   String
  secondName  String
  visitsTotal Int                    @default(0)
  visitsUsed  Int                    @default(0)
  cards       Card[]
  answers     MemberQuestionAnswer[]
  pushSubscriptions PushSubscription[]

  @@map("members")
}

model Card {
  id        String   @id @default(uuid())
  cardCode  String   @unique
  member    Member   @relation(fields: [memberId], references: [id])
  memberId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("cards")
}

model Question {
  id        String                 @id @default(uuid())
  text      String
  isActive  Boolean                @default(true)
  answers   MemberQuestionAnswer[]
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@map("questions")
}

model MemberQuestionAnswer {
  id         String   @id @default(uuid())
  memberId   String
  questionId String
  answer     String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([memberId, questionId])
  @@map("member_question_answers")
}

model PushSubscription {
  id        String   @id @default(uuid())
  memberId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  device    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, isActive])
  @@map("push_subscriptions")
}
