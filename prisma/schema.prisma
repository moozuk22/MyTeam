generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerStatus {
  paid
  warning
  overdue

  @@map("player_status")
}

enum UserRole {
  admin
  coach
}

model Club {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String   @unique
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  emblemUrl     String?  @map("emblem_url")
  imageUrl      String?  @map("image_url")
  imagePublicId String?  @map("image_public_id")
  players       Player[]

  @@map("clubs")
}

model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  password  String
  roles     UserRole[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

model Player {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId             String               @map("club_id") @db.Uuid
  fullName           String               @map("full_name")
  isActive           Boolean              @default(true) @map("is_active")
  cards              Card[]
  status             PlayerStatus         @default(paid)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  jerseyNumber       String?              @map("jersey_number")
  birthDate          DateTime?            @map("birth_date") @db.Date
  teamGroup          Int?                 @map("team_group")
  lastPaymentDate    DateTime?            @map("last_payment_date") @db.Timestamptz(6)
  avatarUrl          String?              @map("avatar_url")
  imageUrl           String?              @map("image_url")
  imagePublicId      String?              @map("image_public_id")
  club               Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  paymentLogs        PaymentLog[]
  pushSubscriptions  PushSubscription[]
  playerNotification PlayerNotification[]

  @@index([clubId])
  @@map("players")
}

model PaymentLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId   String   @map("player_id") @db.Uuid
  paidFor    DateTime @map("paid_for") @db.Timestamptz(6)
  paidAt     DateTime @default(now()) @map("paid_at") @db.Timestamptz(6)
  recordedBy String   @default("admin") @map("recorded_by")
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("payment_logs")
}

model PushSubscription {
  id        String   @id @default(uuid())
  playerId  String   @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  device    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, isActive])
  @@map("push_subscriptions")
}

model PlayerNotification {
  id       String    @id @default(uuid())
  playerId String    @db.Uuid
  type     String
  title    String
  body     String
  url      String?
  sentAt   DateTime  @default(now())
  readAt   DateTime?
  player   Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, sentAt])
  @@index([playerId, readAt])
  @@map("player_notifications")
}

model Card {
  id        String   @id @default(uuid())
  cardCode  String   @unique
  player    Player   @relation(fields: [playerId], references: [id])
  playerId  String   @db.Uuid
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("cards")
}

model CronJobRun {
  id          BigInt    @id @default(autoincrement())
  jobName     String    @map("job_name")
  runYear     Int       @map("run_year")
  runMonth    Int       @map("run_month")
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([jobName, runYear, runMonth])
  @@map("cron_job_runs")
}
