generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlayerStatus {
  paid
  warning
  overdue

  @@map("player_status")
}

model Club {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  emblemUrl String?  @map("emblem_url")
  players   Player[]

  @@map("clubs")
}

model Player {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId             String               @map("club_id") @db.Uuid
  fullName           String               @map("full_name")
  cards              Card[]
  status             PlayerStatus         @default(paid)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  jerseyNumber       String?              @map("jersey_number")
  birthDate          DateTime?            @map("birth_date") @db.Date
  teamGroup          Int?                 @map("team_group")
  lastPaymentDate    DateTime?            @map("last_payment_date") @db.Timestamptz(6)
  avatarUrl          String?              @map("avatar_url")
  club               Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  paymentLogs        PaymentLog[]
  pushSubscriptions  PushSubscription[]
  playerNotification PlayerNotification[]

  @@index([clubId])
  @@map("players")
}

model PaymentLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId   String   @map("player_id") @db.Uuid
  paidFor    String   @map("paid_for")
  paidAt     DateTime @default(now()) @map("paid_at") @db.Timestamptz(6)
  recordedBy String   @default("admin") @map("recorded_by")
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("payment_logs")
}

model PushSubscription {
  id        String   @id @default(uuid())
  playerId  String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  device    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, isActive])
  @@map("push_subscriptions")
}

model PlayerNotification {
  id       String    @id @default(uuid())
  playerId String
  type     String
  title    String
  body     String
  url      String?
  sentAt   DateTime  @default(now())
  readAt   DateTime?
  player   Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, sentAt])
  @@index([playerId, readAt])
  @@map("player_notifications")
}

model Card {
  id        String   @id @default(uuid())
  cardCode  String   @unique
  player    Player   @relation(fields: [playerId], references: [id])
  playerId  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("cards")
}
