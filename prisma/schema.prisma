generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Member {
  id          String @id @default(uuid())
  firstName   String
  secondName  String
  visitsTotal Int    @default(0)
  visitsUsed  Int    @default(0)

  @@map("members")
}

model Admin {
  id         String @id @default(uuid())
  email      String @unique
  password   String
  firstName  String
  secondName String

  @@map("admins")
}
