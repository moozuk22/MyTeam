generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id                     String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  sports                 String?
  createdAt              DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  emblemUrl              String?                     @map("emblem_url")
  imagePublicId          String?                     @map("image_public_id")
  imageUrl               String?                     @map("image_url")
  reminderDay            Int                         @default(25) @map("reminder_day")
  overdueDay             Int                         @default(1) @map("overdue_day")
  reminderHour           Int                         @default(10) @map("reminder_hour")
  reminderMinute         Int                         @default(0) @map("reminder_minute")
  secondReminderDay      Int?                        @map("second_reminder_day")
  secondReminderHour     Int?                        @map("second_reminder_hour")
  secondReminderMinute   Int?                        @map("second_reminder_minute")
  overdueHour            Int                         @default(10) @map("overdue_hour")
  overdueMinute          Int                         @default(0) @map("overdue_minute")
  reminderTz             String                      @default("Europe/Sofia") @map("reminder_tz")
  trainingWeekdays       Int[]                       @default([]) @map("training_weekdays")
  trainingDates          String[]                    @default([]) @map("training_dates")
  trainingTime           String?                     @map("training_time")
  trainingDateTimes      Json?                       @map("training_date_times")
  trainingWindowDays     Int                         @default(30) @map("training_window_days")
  players                Player[]
  adminPushSubscriptions AdminPushSubscription[]
  adminNotifications     AdminNotification[]
  trainingNotes          TrainingNote[]
  trainingGroupSchedules ClubTrainingGroupSchedule[]
  trainingScheduleGroups ClubTrainingScheduleGroup[]
  notifyOnCoachVisit     Boolean                     @default(false) @map("notify_on_coach_visit")

  @@map("clubs")
}

model AdminPushSubscription {
  id        String   @id @default(uuid())
  clubId    String   @map("club_id") @db.Uuid
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent")
  device    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, endpoint])
  @@index([clubId, isActive])
  @@map("admin_push_subscriptions")
}

model ClubTrainingGroupSchedule {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId             String   @map("club_id") @db.Uuid
  teamGroup          Int      @map("team_group")
  trainingWeekdays   Int[]    @default([]) @map("training_weekdays")
  trainingDates      String[] @default([]) @map("training_dates")
  trainingTime       String?  @map("training_time")
  trainingDateTimes  Json?    @map("training_date_times")
  trainingWindowDays Int      @default(30) @map("training_window_days")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  club               Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, teamGroup])
  @@index([clubId])
  @@map("club_training_group_schedules")
}

model ClubTrainingScheduleGroup {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId             String   @map("club_id") @db.Uuid
  name               String
  teamGroups         Int[]    @default([]) @map("team_groups")
  trainingWeekdays   Int[]    @default([]) @map("training_weekdays")
  trainingDates      String[] @default([]) @map("training_dates")
  trainingTime       String?  @map("training_time")
  trainingDateTimes  Json?    @map("training_date_times")
  trainingWindowDays Int      @default(30) @map("training_window_days")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  club               Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("club_training_schedule_groups")
}

model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  password  String
  roles     UserRole[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

model Player {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId             String               @map("club_id") @db.Uuid
  fullName           String               @map("full_name")
  status             PlayerStatus         @default(paid)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  jerseyNumber       String?              @map("jersey_number")
  birthDate          DateTime?            @map("birth_date") @db.Date
  teamGroup          Int?                 @map("team_group")
  lastPaymentDate    DateTime?            @map("last_payment_date") @db.Timestamptz(6)
  isActive           Boolean              @default(true) @map("is_active")
  cards              Card[]
  images             Image[]
  paymentLogs        PaymentLog[]
  paymentWaivers     PaymentWaiver[]
  playerNotification PlayerNotification[]
  adminNotifications AdminNotification[]
  club               Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  pushSubscriptions  PushSubscription[]
  trainingOptOuts    TrainingOptOut[]
  discountUsages     PartnerDiscountUsage[]

  @@index([clubId])
  @@map("players")
}

model TrainingOptOut {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId     String   @map("player_id") @db.Uuid
  trainingDate DateTime @map("training_date") @db.Date
  reasonCode   String?  @map("reason_code")
  reasonText   String?  @map("reason_text")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, trainingDate])
  @@index([trainingDate])
  @@map("training_opt_outs")
}

model TrainingNote {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clubId          String   @map("club_id") @db.Uuid
  trainingDate    DateTime @map("training_date") @db.Date
  note            String?
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, trainingDate])
  @@index([trainingDate])
  @@map("training_notes")
}

model Image {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId    String  @map("player_id") @db.Uuid
  imageUrl    String  @map("image_url")
  isAdminView Boolean @map("is_admin_view")
  player      Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("images")
}

model PaymentLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId   String   @map("player_id") @db.Uuid
  paidAt     DateTime @default(now()) @map("paid_at") @db.Timestamptz(6)
  recordedBy String   @default("admin") @map("recorded_by")
  paidFor    DateTime @map("paid_for") @db.Timestamptz(6)
  player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("payment_logs")
}

model PaymentWaiver {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  playerId  String   @map("player_id") @db.Uuid
  waivedFor DateTime @map("waived_for") @db.Timestamptz(6)
  reason    String?
  createdBy String   @default("admin") @map("created_by")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, waivedFor])
  @@index([playerId])
  @@map("payment_waivers")
}

model PushSubscription {
  id        String   @id @default(uuid())
  playerId  String   @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  device    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  member    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, isActive])
  @@map("push_subscriptions")
}

model PlayerNotification {
  id       String    @id @default(uuid())
  playerId String    @db.Uuid
  type     String
  title    String
  body     String
  url      String?
  sentAt   DateTime  @default(now())
  readAt   DateTime?
  player   Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, sentAt])
  @@index([playerId, readAt])
  @@map("player_notifications")
}

model AdminNotification {
  id       String    @id @default(uuid())
  clubId   String    @map("club_id") @db.Uuid
  playerId String?   @map("player_id") @db.Uuid
  type     String
  title    String
  body     String
  url      String?
  sentAt   DateTime  @default(now()) @map("sent_at")
  readAt   DateTime? @map("read_at")
  club     Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  player   Player?   @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([clubId, sentAt])
  @@index([clubId, readAt])
  @@index([clubId, playerId])
  @@map("admin_notifications")
}

model Card {
  id        String   @id @default(uuid())
  cardCode  String   @unique
  playerId  String   @db.Uuid
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  player    Player   @relation(fields: [playerId], references: [id])

  @@map("cards")
}

model CronJobRun {
  id          BigInt    @id @default(autoincrement())
  jobName     String    @map("job_name")
  runYear     Int       @map("run_year")
  runMonth    Int       @map("run_month")
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  failedAt    DateTime? @map("failed_at") @db.Timestamptz(6)
  errorMessage String?  @map("error_message")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([jobName, runYear, runMonth])
  @@map("cron_job_runs")
}

model PartnerDiscountUsage {
  id        String   @id @default(uuid()) @db.Uuid
  playerId  String   @map("player_id") @db.Uuid
  partner   String
  action    String
  date      DateTime @db.Date
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@index([date])
  @@index([partner, date])
  @@map("partner_discount_usage")
}

model PageClick {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action    String   @default("unknown")
  clickedAt DateTime @default(now()) @map("clicked_at") @db.Timestamptz(6)

  @@index([clickedAt])
  @@index([action])
  @@map("page_clicks")
}

enum PlayerStatus {
  paid
  warning
  overdue

  @@map("player_status")
}

enum UserRole {
  admin
  coach
}
